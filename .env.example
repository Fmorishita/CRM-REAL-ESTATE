# ──────────────────────────────────────────────────────────────────────────────
# REALTOR PRO CRM — Environment variables
# Copy to .env.local and fill in. Every integration falls back to a mock adapter
# when its variables are missing, so the app runs in demo mode with no env at all.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Forces demo mode (in-memory seed data) even if a database is configured.
DEMO_MODE=true
# Opt in to real Supabase Auth sign-in (Phase 21). Requires DEMO_MODE off, a
# database, and Supabase configured. Left empty/false, the app uses the demo
# owner context so the public demo is never locked behind a login wall.
AUTH_ENABLED=

# ── Supabase (Phase 2 — database, auth, realtime, storage) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooled connection for the app (Supavisor/pgbouncer)
DATABASE_URL=
# Direct connection for Prisma migrations
DIRECT_URL=

# ── AI providers (leave empty to use the mock provider) ──────────────────────
# Each AI task can route to a different provider/model (Settings → IA).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
# Open-source / free-friendly backends (all OpenAI-compatible):
# Groq — free, very fast hosting of Llama/Qwen.
GROQ_API_KEY=
# OpenRouter — one key, hundreds of models (many `:free`).
OPENROUTER_API_KEY=
# Ollama — local/self-hosted models. Set the base URL to enable (no key needed).
OLLAMA_BASE_URL=

# ── Channels (Phase 19 — leave empty to use mock adapters) ───────────────────
# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta Graph API (Instagram + Facebook Messenger + Lead Ads)
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
# Email (Gmail API or SMTP)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
EMAIL_FROM=

# ── Maps & calendar (Phases 11/19 — mock route planner when empty) ───────────
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Outbound webhooks / automation (Phase 12+) ───────────────────────────────
WEBHOOK_SIGNING_SECRET=

# ── Billing (V2) ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
